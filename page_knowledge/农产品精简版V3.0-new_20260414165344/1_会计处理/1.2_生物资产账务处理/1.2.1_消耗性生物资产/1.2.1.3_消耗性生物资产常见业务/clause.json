{
  "clauseId": "51274b8dc0194a48a1748a6bf7afbe2d",
  "clauseName": "1.2.1.3_农产品精简版V3.0-new（20260414165344）",
  "clauseNumber": "1.2.1.3",
  "clauseContent": "1.2.1.3.  消耗性生物资产常见业务\n<div class=\"quill-better-table-wrapper\"><table class=\"quill-better-table\" style=\"width: 100%;\"><colgroup><col width=\"auto\"><col width=\"auto\"><col width=\"auto\"><col width=\"auto\"></colgroup><tbody><tr data-row=\"1\"><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">业务场景</strong></p></td><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">会计分录</strong></p></td><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">具体说明</strong></p></td><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">政策依据</strong></p></td></tr><tr data-row=\"2\"><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（1）外购幼崽、幼苗等</span></p></td><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：消耗性生物资产—XX&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：银行存款/应付账款</span></p></td><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">成本包括购买价款、相关税费、运输费、保险费以及可直接归属于购买该资产的其他支出。</span></p></td><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第5号—生物资产》第七条</span></p></td></tr><tr data-row=\"3\"><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（2）发生饲养费用（饲料、人工、防疫等）</span></p></td><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：消耗性生物资产—XX&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：原材料/应付职工薪酬/银行存款等</span></p></td><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">出售前发生的必要支出需资本化</span></p></td><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第5号—生物资产》第八条</span></p></td></tr><tr data-row=\"4\"><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（3）自行营造的林木郁闭前成本</span></p></td><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：消耗性生物资产—林木&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：原材料/应付职工薪酬/银行存款等</span></p></td><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">郁闭前的的造林费、抚育费、营林设施费、良种试验费、调查设计费和应分摊的间接费用等必要支出</span></p></td><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第5号—生物资产》第八条</span></p></td></tr><tr data-row=\"5\"><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（4）收获农产品（如采摘苹果、收割小麦）</span></p></td><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：农产品/库存商品</span></p><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;存货跌价准备—消耗性生物资产（若涉及）</span></p><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：消耗性生物资产</span></p></td><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">将收获时的账面价值结转至农产品；对于不通过入库直接销售的鲜活产品等，按实际成本，借记“主营业务成本”科目。</span></p></td><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第5号—生物资产》第四条</span></p></td></tr><tr data-row=\"6\"><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（5）对外出售</span></p></td><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">确认收入：</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：银行存款&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：主营业务收入&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;应交税费—应交增值税（销项税额）【一般纳税人】/应交税费—应交增值税【小规模纳税人】</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">结转成本：&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：主营业务成本&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：农产品/库存商品</span></p></td><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">若为免税业务，则无“应交税费—应交增值税（销项税额）”/“应交税费—应交增值税”科目；若收获时未计入农产品或库存商品，则直接从“消耗性生物资产”结转成本。</span></p></td><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第14号—收入(2017年修订)》第四条</span></p></td></tr><tr data-row=\"7\"><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（6）盘亏或死亡</span></p></td><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">发现盘亏或死亡时&nbsp;：</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：待处理财产损溢&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：消耗性生物资产/农产品/库存商品&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(管理不善需转出进项税：</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;贷：应交税费—应交增值税(进项税额转出))</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">批准后处理&nbsp;：</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：其他应收款(赔款)&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;管理费用(管理不善)&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;营业外支出(自然灾害)&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：待处理财产损溢</span></p></td><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">小企业准则下，损失统一计入“营业外支出”</span></p></td><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">《企业会计准则第&nbsp;5&nbsp;号—生物资产》（财会〔2006〕3号）第二十六条；《企业会计准则第1号—存货》第二十一条</span></p></td></tr><tr data-row=\"8\"><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（7）产品临期或过期低价销售</span></p></td><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">计提跌价准备（若可变现净值低于成本）：&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：资产减值损失&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：存货跌价准备&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">销售时：</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：银行存款&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：主营业务收入&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;应交税费—应交增值税（销项税额）【一般纳税人】/应交税费—应交增值税【小规模纳税人】</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：主营业务成本&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;存货跌价准备&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：库存商品</span></p></td><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><br></p></td><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"4\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">企业会计准则需要计提减值准备，小企业会计准则无需计提；已计提但未实际发生的跌价准备，企业所得税汇算清缴时要进行纳税调增。</span></p></td></tr></tbody></table>",
