{
  "clauseId": "2a898060aaf84b2eba14acb9efe3257d",
  "clauseName": "1.2.2.3_农产品精简版V3.0-new（20260414165344）",
  "clauseNumber": "1.2.2.3",
  "clauseContent": "1.2.2.3.  生产性生物资产常见业务\n<div class=\"quill-better-table-wrapper\"><table class=\"quill-better-table\" style=\"width: 100%;\"><colgroup><col width=\"auto\"><col width=\"auto\"><col width=\"auto\"></colgroup><tbody><tr data-row=\"1\"><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">业务场景</strong></p></td><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">会计分录&nbsp;(执行企业会计准则)</strong></p></td><td data-row=\"1\" rowspan=\"1\" colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\" style=\"background-color: rgb(245, 247, 250);\"><p class=\"qlbt-cell-line ql-align-center\" data-row=\"1\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\" data-cell-bg=\"rgb(245, 247, 250)\"><strong style=\"color: rgb(51, 51, 51);\">说明</strong></p></td></tr><tr data-row=\"2\"><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（1）外购产畜/果树（未成熟）</span></p></td><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：生产性生物资产—未成熟生产性生物资产&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：银行存款</span></p></td><td data-row=\"2\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"2\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">达到预定生产经营目的前</span></p></td></tr><tr data-row=\"3\"><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（2）发生饲养、管护等成本</span></p></td><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：生产性生物资产—未成熟生产性生物资产&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：原材料/应付职工薪酬/银行存款</span></p></td><td data-row=\"3\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"3\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">资本化</span></p></td></tr><tr data-row=\"4\"><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（3）达到预定生产经营目的（如开始产奶）</span></p></td><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：生产性生物资产—成熟生产性生物资产</span></p><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：生产性生物资产—未成熟生产性生物资产</span></p></td><td data-row=\"4\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"4\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">从“未成熟”转入“成熟”</span></p></td></tr><tr data-row=\"5\"><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（4）成熟后发生饲料、防疫、折旧等支出</span></p></td><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：农业生产成本/生产成本</span></p><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：原材料/应付职工薪酬/生产性生物资产累计折旧/银行存款等</span></p></td><td data-row=\"5\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"5\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">归集为产品成本,不影响利润表中的损益</span></p></td></tr><tr data-row=\"6\"><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（5）收获农产品验收入库（如牛奶、鸡蛋）</span></p></td><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：农产品/库存商品&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：农业生产成本/生产成本</span></p></td><td data-row=\"6\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"6\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">将归集的成本转入“农产品”或“库存商品”</span></p></td></tr><tr data-row=\"7\"><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（6）计提折旧</span></p></td><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：农业生产成本/生产成本/管理费用&nbsp;</span></p><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：生产性生物资产累计折旧</span></p></td><td data-row=\"7\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"7\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">根据资产用途确认借方科目</span></p></td></tr><tr data-row=\"8\"><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">（7）出售生产性生物资产（如淘汰奶牛）</span></p></td><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">借：银行存款/应收账款等</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;生产性生物资产累计折旧</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;生产性生物资产减值准备（若涉及）</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">贷：生产性生物资产</span></p><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;资产处置损益（或借方）</span></p></td><td data-row=\"8\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"8\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">差额计入“资产处置损益”（小企业准则计入“营业外收入”或“营业外支出”）</span></p></td></tr><tr data-row=\"9\"><td data-row=\"9\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">自行繁殖小奶牛</span></p></td><td data-row=\"9\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;归集母牛孕期及接产成本：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：农业生产成本—繁育成本</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：原材料/应付职工薪酬等</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">小牛出生时：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;-&nbsp;作为消耗性（育肥出售）：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;借：消耗性生物资产—犊牛</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;贷：农业生产成本—繁育成本</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;-&nbsp;作为生产性（留种产奶）：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;借：生产性生物资产—未成熟(犊牛)</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;贷：农业生产成本—繁育成本</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">后续饲养小牛时：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;-&nbsp;作为消耗性（育肥出售）：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;借：消耗性生物资产—犊牛</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;贷：原材料—饲料</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;应付职工薪酬/银行存款等</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;-&nbsp;作为生产性（留种产奶）：</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;借：生产性生物资产—未成熟(犊牛)</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;贷：原材料—饲料</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;应付职工薪酬</span></p><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;银行存款</span></p></td><td data-row=\"9\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"9\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">小牛成本为分娩过程中发生的必要支出</span></p></td></tr><tr data-row=\"10\"><td data-row=\"10\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"1\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">生产性生物资产死亡</span></p></td><td data-row=\"10\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">发现时：</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：待处理财产损溢</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;生产性生物资产累计折旧</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：生产性生物资产</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;应交税费—应交增值税（进项税额转出）（仅当管理不善造成时需做，否则可省略）</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">批准后处理：</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;借：其他应收款（如有保险赔款或责任人赔款）</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;营业外支出（用于非正常损失，如因病死亡）</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;管理费用（如因管理不善造成）</span></p><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"2\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">&nbsp;&nbsp;&nbsp;贷：待处理财产损溢</span></p></td><td data-row=\"10\" rowspan=\"1\" colspan=\"1\"><p class=\"qlbt-cell-line\" data-row=\"10\" data-cell=\"3\" data-rowspan=\"1\" data-colspan=\"1\"><span style=\"color: rgb(51, 51, 51);\">损失原因需清晰，以区分责任</span></p></td></tr></tbody></table>",
